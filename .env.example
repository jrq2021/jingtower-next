# ═══════════════════════════════════════════════
# 镜塔 Tarot — 环境变量配置
# 复制此文件为 .env 并填入你的配置
# 没有真实 key 时项目仍可运行（使用 mock）
# ═══════════════════════════════════════════════

# ─── AI Provider ───
# Provider 类型: mock | deepseek | openai | openai-compatible
AI_PROVIDER=mock

# API Key（mock 模式不需要）
AI_API_KEY=

# API Base URL
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:  https://api.openai.com/v1
AI_BASE_URL=https://api.deepseek.com/v1

# 模型名称
# DeepSeek: deepseek-chat
# OpenAI:   gpt-4o-mini
AI_MODEL=deepseek-chat

# 超时时间（毫秒）
AI_TIMEOUT_MS=20000

# ─── Data Provider ───
# 数据存储: mock（内存 Map）| supabase | postgres
DATA_PROVIDER=mock

# ─── Analytics（埋点） ───
# Provider: mock | plausible | posthog | ga
ANALYTICS_PROVIDER=mock
ANALYTICS_ENDPOINT=
ANALYTICS_API_KEY=

# ─── Payment（支付） ───
# Provider: mock | wechat | alipay | stripe
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_ENABLED=true

# ─── Site 公开变量（NEXT_PUBLIC_ 前缀） ───
# 网站域名（用于 metadataBase、OG 图片等）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 匿名用户 ID 的 localStorage key
NEXT_PUBLIC_ANONYMOUS_ID_KEY=jingtower_anonymous_id
